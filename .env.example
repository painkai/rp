TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 분석기 선택: ollama (기본) 또는 claude
ANALYZER=ollama

# Ollama 설정 (ANALYZER=ollama 일 때)
OLLAMA_HOST=http://192.168.x.x:11434
OLLAMA_MODEL=moondream

# Claude 설정 (ANALYZER=claude 일 때)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 웹 스트리밍 포트
STREAM_PORT=5000
# 외부 접근 시 기본 인증 (비워두면 인증 없음)
STREAM_USER=
STREAM_PASS=

# 동작 감지 민감도 (변화 픽셀 수, 낮을수록 민감)
MOTION_THRESHOLD=3000

# 동작 감지 후 캡처까지 대기 시간 (초)
CAPTURE_DELAY=2
# 동작 감지 후 캡처 시 재확인 임계값 (이 이하면 알림 건너뜀)
CONFIRM_THRESHOLD=1000
# 전체 프레임 대비 변화 비율 초과 시 조명 변화로 판단 (0.0~1.0)
LIGHTING_THRESHOLD=0.6

# 알림 발송 후 재감지 대기 시간 (초)
COOLDOWN_ALERT=30
# 알림 미발송(변화 없음) 후 재감지 대기 시간 (초)
COOLDOWN_NO_ALERT=10

# 연속 감지 시 텔레그램 최대 발송 횟수
CONTINUOUS_ALERT_LIMIT=2
# 연속 감지 N분 경과 시 배경 강제 갱신
CONTINUOUS_BG_MINUTES=3

# 배경 자동 갱신 주기 (초, 기본 2시간)
BG_UPDATE_INTERVAL=7200
# 배경 변화 감지 임계값 (픽셀, 이 값 이상이면 재확인)
BG_CHANGE_THRESHOLD=50000

# 라벨링 PC 수신 서버 주소 (label_bot.py 사용 시)
PC_RECEIVER=http://192.168.x.x:8765
